### كيف يُرسم الـ Block (BlockRenderer — لا switch/case)

```tsx
// blocks/BlockRenderer.tsx
import HeadingBlock   from './heading/component';
import ParagraphBlock from './paragraph/component';
import ButtonBlock    from './button/component';
import ImageBlock     from './image/component';

// Registry-based — لا switch/case
const BlockComponentMap: Record<string, React.FC<any>> = {
  heading:   HeadingBlock,
  paragraph: ParagraphBlock,
  button:    ButtonBlock,
  image:     ImageBlock,
};

interface BlockData {
  id: string;
  type: string;
  settings: Record<string, any>;
}

export function BlockRenderer({ blocks }: { blocks: BlockData[] }) {
  return (
    <>
      {blocks.map(block => {
        const Component = BlockComponentMap[block.type];
        if (!Component) return null;
        return <Component key={block.id} settings={block.settings} />;
      })}
    </>
  );
}
```

